# ============================================================
#  AeroTrack — Environment Variables
#  Copy this file to .env and fill in your credentials
#  NEVER commit your real .env file to GitHub!
# ============================================================

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OpenSky Network API ───────────────────────────────────
# Register free at: https://opensky-network.org/index.php?option=com_users&view=registration
# Get credentials at: https://opensky-network.org/my-opensky/account
#
# Leave blank to use anonymous mode (400 req/day limit)
# With account: 4000 req/day limit
OPENSKY_CLIENT_ID=your_client_id_here
OPENSKY_CLIENT_SECRET=your_client_secret_here

# ── Cache ─────────────────────────────────────────────────
# How long to cache flight data (seconds). Default: 30s
CACHE_TTL=30

# ── Rate Limiting ─────────────────────────────────────────
# Max requests per IP per 15 minutes
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────────────────
# Allowed origins (comma separated). Use * for all (dev only)
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=*
